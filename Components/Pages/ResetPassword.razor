@page "/restablecer-password/{Token}"
@layout Layout._Layout
@inject Sistema_de_Gestion_de_Activos.Application.Interfaces.IAuthService AuthService

@code {
    [Parameter] public string Token { get; set; } = string.Empty;

    private bool showPassword1 = false;
    private bool showPassword2 = false;
    private bool isLoading = false;
    private string newPassword = string.Empty;
    private string confirmPassword = string.Empty;
    private string error = string.Empty;
    private bool success = false;

    private string PasswordType1 => showPassword1 ? "text" : "password";
    private string PasswordType2 => showPassword2 ? "text" : "password";

    private async Task HandleSubmit()
    {
        error = string.Empty;
        success = false;

        if (string.IsNullOrWhiteSpace(newPassword))
        {
            error = "La nueva contraseña es requerida.";
            return;
        }

        if (newPassword.Length < 8)
        {
            error = "La contraseña debe tener al menos 8 caracteres.";
            return;
        }

        if (newPassword != confirmPassword)
        {
            error = "Las contraseñas no coinciden.";
            return;
        }

        isLoading = true;

        try
        {
            var tokenLimpio = Uri.UnescapeDataString(Token);
            var result = await AuthService.RestablecerContrasenaAsync(tokenLimpio, newPassword);

            if (result)
            {
                success = true;
            }
            else
            {
                error = "El enlace es inválido o ha expirado.";
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}

<div class="flex min-h-screen w-full items-center justify-center bg-gray-50 p-4 dark:bg-gray-950">
    <Card class="w-full max-w-[400px]">
        <CardHeader class="flex flex-col items-center space-y-4 pb-6 pt-8">
            <div class="flex h-16 w-16 items-center justify-center rounded-xl bg-primary-600 text-white shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                </svg>
            </div>
            <div class="text-center">
                <h1 class="text-lg font-semibold text-gray-900 dark:text-white">
                    Nueva Contraseña
                </h1>
                <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
                    Ingrese su nueva contraseña para acceder al sistema.
                </p>
            </div>
        </CardHeader>

        <CardContent>
            @if (success)
            {
                <div class="rounded-md bg-green-50 p-4 text-sm text-green-800 dark:bg-green-900/30 dark:text-green-400">
                    Su contraseña ha sido restablecida exitosamente.
                </div>
                <div class="mt-6 text-center">
                    <a href="/login" class="text-sm font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400">
                        Ir al inicio de sesión
                    </a>
                </div>
            }
            else
            {
                <EditForm Model="@this" OnSubmit="HandleSubmit" class="space-y-4">
                    <div class="relative">
                        <Input Label="Nueva Contraseña"
                               Type="@PasswordType1"
                               placeholder="••••••••"
                               @bind-Value="newPassword" />

                        <button type="button"
                                @onclick="() => showPassword1 = !showPassword1"
                                class="absolute right-3 top-[34px] text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
                            @if (showPassword1)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.88 9.88a3 3 0 1 0 4.24 4.24" /><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68" /><path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61" /><line x1="2" x2="22" y1="2" y2="22" /></svg>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z" /><circle cx="12" cy="12" r="3" /></svg>
                            }
                        </button>
                    </div>

                    <div class="relative">
                        <Input Label="Confirmar Contraseña"
                               Type="@PasswordType2"
                               placeholder="••••••••"
                               @bind-Value="confirmPassword" />

                        <button type="button"
                                @onclick="() => showPassword2 = !showPassword2"
                                class="absolute right-3 top-[34px] text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
                            @if (showPassword2)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.88 9.88a3 3 0 1 0 4.24 4.24" /><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68" /><path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61" /><line x1="2" x2="22" y1="2" y2="22" /></svg>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z" /><circle cx="12" cy="12" r="3" /></svg>
                            }
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(error))
                    {
                        <div class="rounded-md bg-red-50 p-3 text-sm text-red-600 dark:bg-red-900/20 dark:text-red-400">
                            @error
                        </div>
                    }

                    <Button Type="submit"
                            Class="w-full mt-2 h-11"
                            IsLoading="isLoading">
                        Restablecer Contraseña
                    </Button>
                </EditForm>
            }
        </CardContent>
    </Card>
</div>
