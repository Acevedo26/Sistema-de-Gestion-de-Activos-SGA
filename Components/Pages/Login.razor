@page "/login"
@layout Layout.EmptyLayout
@inject NavigationManager Navigation
@inject Sistema_de_Gestion_de_Activos.Application.Interfaces.IAuthService AuthService
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider

@code {
    private bool showPassword = false;
    private bool isLoading = false;
    private string email = string.Empty;
    private string password = string.Empty;
    private string error = string.Empty;

    private string PasswordType => showPassword ? "text" : "password";

    private async Task HandleLogin()
    {
        error = string.Empty;

        if (string.IsNullOrWhiteSpace(email) || !email.Contains("@"))
        {
            error = "Por favor ingrese un correo válido.";
            return;
        }

        if (string.IsNullOrWhiteSpace(password))
        {
            error = "La contraseña es requerida.";
            return;
        }

        isLoading = true;

        try
        {
            var usuario = await AuthService.ValidarCredencialesAsync(email, password);
            if (usuario != null)
            {
                var customAuthStateProvider = (Sistema_de_Gestion_de_Activos.Providers.CustomAuthStateProvider)AuthStateProvider;
                await customAuthStateProvider.MarkUserAsAuthenticated(usuario);
                Navigation.NavigateTo("/dashboard");
            }
            else
            {
                error = "Correo o contraseña incorrectos, o la cuenta está inactiva.";
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}

<div class="flex min-h-screen w-full items-center justify-center bg-gray-50 p-4 dark:bg-gray-950">
    <Card class="w-full max-w-[400px]">
        <CardHeader class="flex flex-col items-center space-y-4 pb-6 pt-8">
            <div class="flex h-16 w-16 items-center justify-center rounded-xl bg-primary-600 text-white shadow-sm">
                <!-- Icono Building2 -->
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M10 22v-9.5a.5.5 0 0 0-.5-.5h-2a.5.5 0 0 0-.5.5V22" />
                    <path d="M4 22h16" />
                    <path d="M14 22v-5.5a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 .5.5V22" />
                    <path d="M6 12h12a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2Z" />
                    <path d="M6 8h2" />
                    <path d="M16 8h2" />
                    <path d="M6 12h2" />
                    <path d="M16 12h2" />
                </svg>
            </div>
            <div class="text-center">
                <h1 class="text-lg font-semibold text-gray-900 dark:text-white">
                    Acceso al Sistema de Gestión de Activos
                </h1>
            </div>
        </CardHeader>

        <CardContent>
            <EditForm Model="@this" OnSubmit="HandleLogin" class="space-y-4">
                <Input Label="Correo Electrónico"
                       Type="email"
                       placeholder="correo@empresa.com"
                       @bind-Value="email"
                       Error="@(error != string.Empty && string.IsNullOrWhiteSpace(email) ? "Requerido" : null)" />

                <div class="relative">
                    <Input Label="Contraseña"
                           Type="@PasswordType"
                           placeholder="••••••••"
                           @bind-Value="password"
                           Error="@(error != string.Empty && string.IsNullOrWhiteSpace(password) ? "Requerido" : null)" />

                    <button type="button"
                            @onclick="() => showPassword = !showPassword"
                            class="absolute right-3 top-[34px] text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
                        @if (showPassword)
                        {
                            <!-- EyeOff -->
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24" />
                                <path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68" />
                                <path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61" />
                                <line x1="2" x2="22" y1="2" y2="22" />
                            </svg>
                        }
                        else
                        {
                            <!-- Eye -->
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z" />
                                <circle cx="12" cy="12" r="3" />
                            </svg>
                        }
                    </button>
                </div>

                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="rounded-md bg-red-50 p-3 text-sm text-red-600 dark:bg-red-900/20 dark:text-red-400">
                        @error
                    </div>
                }

                <Button Type="submit"
                        Class="w-full mt-2 h-11"
                        IsLoading="isLoading">
                    Iniciar Sesión
                </Button>
            </EditForm>

            <div class="mt-4 text-center">
                <a href="/recuperar-password"
                   class="text-sm text-primary-600 hover:text-primary-700 hover:underline dark:text-primary-400">
                    ¿Olvidó su contraseña?
                </a>
            </div>
        </CardContent>

        <CardFooter class="justify-center border-t border-gray-100 pb-6 pt-6 dark:border-gray-800">
            <p class="text-xs text-gray-500 dark:text-gray-400">
                Protegido por políticas de seguridad corporativa.
            </p>
        </CardFooter>
    </Card>
</div>
