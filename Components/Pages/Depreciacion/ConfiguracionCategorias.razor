@page "/depreciacion/configuracion-categorias"
@rendermode InteractiveServer
@layout Layout._Layout
@using Sistema_de_Gestion_de_Activos.Application.DTOs.Depreciacion
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider

@code {
    private List<CategoriaResponseDto> categorias = new();
    private bool isLoading = true;
    private string error = string.Empty;
    private string successMessage = string.Empty;
    private bool isAdmin = false;

    // Edición inline
    private Guid? editandoId = null;
    private int vidaUtilEditada;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        isAdmin = user.IsInRole("Administrador");

        await CargarCategorias();
    }

    private async Task CargarCategorias()
    {
        isLoading = true;
        error = string.Empty;
        try
        {
            var result = await Http.GetFromJsonAsync<List<CategoriaResponseDto>>("api/categorias");
            categorias = result ?? new();
        }
        catch (Exception ex)
        {
            error = $"Error al cargar categorías: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void IniciarEdicion(CategoriaResponseDto categoria)
    {
        editandoId = categoria.Id;
        vidaUtilEditada = categoria.VidaUtil;
        successMessage = string.Empty;
        error = string.Empty;
    }

    private void CancelarEdicion()
    {
        editandoId = null;
    }

    private async Task GuardarVidaUtil(Guid categoriaId)
    {
        if (vidaUtilEditada < 1 || vidaUtilEditada > 100)
        {
            error = "La vida útil debe estar entre 1 y 100 años.";
            return;
        }

        error = string.Empty;
        try
        {
            var dto = new CategoriaVidaUtilUpdateDto { VidaUtil = vidaUtilEditada };
            var response = await Http.PutAsJsonAsync($"api/categorias/{categoriaId}", dto);

            if (response.IsSuccessStatusCode)
            {
                successMessage = "Vida útil actualizada correctamente.";
                editandoId = null;
                await CargarCategorias();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                error = $"Error al actualizar: {body}";
            }
        }
        catch (Exception ex)
        {
            error = $"Error de conexión: {ex.Message}";
        }
    }
}

<CascadingAuthenticationState>
<AuthorizeView>
    <Authorized>

<div class="dep-config-container">
    <div class="dep-config-header">
        <div>
            <h1 class="dep-config-title">Configuración de Categorías</h1>
            <p class="dep-config-subtitle">Configure la vida útil por categoría para el cálculo de depreciación.</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="dep-alert dep-alert-success">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>@successMessage</span>
        </div>
    }

    @if (!string.IsNullOrEmpty(error))
    {
        <div class="dep-alert dep-alert-error">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
            <span>@error</span>
        </div>
    }

    <div class="dep-info-banner">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        <span>Los cambios en la vida útil solo aplicarán a activos nuevos registrados a partir de hoy.</span>
    </div>

    <div class="dep-card">
        <div class="dep-table-wrapper">
            <table class="dep-table">
                <thead>
                    <tr>
                        <th>Categoría</th>
                        <th>Vida Útil (años)</th>
                        <th class="dep-th-actions">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (isLoading)
                    {
                        <tr>
                            <td colspan="3" class="dep-td-center">
                                <div class="dep-loading">
                                    <div class="dep-spinner"></div>
                                    <span>Cargando categorías...</span>
                                </div>
                            </td>
                        </tr>
                    }
                    else if (!categorias.Any())
                    {
                        <tr>
                            <td colspan="3" class="dep-td-center">No hay categorías registradas.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var cat in categorias)
                        {
                            <tr>
                                <td class="dep-td-nombre">@cat.Nombre</td>
                                <td>
                                    @if (editandoId == cat.Id)
                                    {
                                        <div class="dep-edit-group">
                                            <input type="number" min="1" max="100"
                                                   @bind="vidaUtilEditada"
                                                   class="dep-input-edit" />
                                            <span class="dep-edit-hint">años</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="dep-vida-util-badge">@cat.VidaUtil años</span>
                                    }
                                </td>
                                <td class="dep-td-actions">
                                    @if (editandoId == cat.Id)
                                    {
                                        <button class="dep-btn dep-btn-save" @onclick="() => GuardarVidaUtil(cat.Id)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                            Guardar
                                        </button>
                                        <button class="dep-btn dep-btn-cancel" @onclick="CancelarEdicion">
                                            Cancelar
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="dep-btn dep-btn-edit"
                                                disabled="@(!isAdmin)"
                                                @onclick="() => IniciarEdicion(cat)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                            Editar
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

    </Authorized>
    <NotAuthorized>
        <div class="dep-denied">
            <h2>Acceso Denegado</h2>
            <p>Debe iniciar sesión para acceder a esta página.</p>
        </div>
    </NotAuthorized>
</AuthorizeView>
</CascadingAuthenticationState>

<style>
    .dep-config-container {
        min-height: 100vh;
        padding: 1.5rem;
        background: #0a0a0f;
        color: #e2e8f0;
    }

    .dep-config-header {
        max-width: 72rem;
        margin: 0 auto 1.5rem;
    }

    .dep-config-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: #f1f5f9;
        margin: 0;
    }

    .dep-config-subtitle {
        margin-top: 0.25rem;
        font-size: 0.875rem;
        color: #94a3b8;
    }

    /* Alertas */
    .dep-alert {
        max-width: 72rem;
        margin: 0 auto 1rem;
        padding: 0.75rem 1rem;
        border-radius: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
    }

    .dep-alert-success {
        background: rgba(34, 197, 94, 0.1);
        border: 1px solid rgba(34, 197, 94, 0.3);
        color: #4ade80;
    }

    .dep-alert-error {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.3);
        color: #f87171;
    }

    /* Banner informativo */
    .dep-info-banner {
        max-width: 72rem;
        margin: 0 auto 1.5rem;
        padding: 0.75rem 1rem;
        border-radius: 0.5rem;
        background: rgba(59, 130, 246, 0.08);
        border: 1px solid rgba(59, 130, 246, 0.25);
        color: #93c5fd;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.85rem;
    }

    /* Card */
    .dep-card {
        max-width: 72rem;
        margin: 0 auto;
        background: #111827;
        border: 1px solid #1e293b;
        border-radius: 0.75rem;
        overflow: hidden;
    }

    .dep-table-wrapper {
        overflow-x: auto;
    }

    /* Tabla */
    .dep-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
        font-size: 0.875rem;
    }

    .dep-table thead tr {
        background: #0f172a;
        border-bottom: 1px solid #1e293b;
    }

    .dep-table th {
        padding: 0.875rem 1.5rem;
        font-weight: 500;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #94a3b8;
    }

    .dep-th-actions {
        text-align: right;
    }

    .dep-table tbody tr {
        border-bottom: 1px solid #1e293b;
        transition: background 0.15s ease;
    }

    .dep-table tbody tr:hover {
        background: rgba(30, 41, 59, 0.5);
    }

    .dep-table td {
        padding: 0.875rem 1.5rem;
        color: #cbd5e1;
    }

    .dep-td-nombre {
        font-weight: 500;
        color: #f1f5f9;
    }

    .dep-td-center {
        text-align: center;
        padding: 2rem 1.5rem;
        color: #64748b;
    }

    .dep-td-actions {
        text-align: right;
        white-space: nowrap;
    }

    /* Badge vida útil */
    .dep-vida-util-badge {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        background: rgba(99, 102, 241, 0.15);
        border: 1px solid rgba(99, 102, 241, 0.3);
        border-radius: 9999px;
        color: #a5b4fc;
        font-size: 0.8rem;
        font-weight: 500;
    }

    /* Input edición */
    .dep-edit-group {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .dep-input-edit {
        width: 5rem;
        padding: 0.375rem 0.5rem;
        border: 1px solid #334155;
        border-radius: 0.375rem;
        background: #0f172a;
        color: #f1f5f9;
        font-size: 0.875rem;
        text-align: center;
        outline: none;
        transition: border-color 0.15s;
    }

    .dep-input-edit:focus {
        border-color: #6366f1;
        box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2);
    }

    .dep-edit-hint {
        font-size: 0.8rem;
        color: #64748b;
    }

    /* Botones */
    .dep-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.375rem 0.875rem;
        border-radius: 0.375rem;
        font-size: 0.8rem;
        font-weight: 500;
        border: 1px solid transparent;
        cursor: pointer;
        transition: all 0.15s ease;
    }

    .dep-btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }

    .dep-btn-edit {
        background: rgba(99, 102, 241, 0.1);
        border-color: rgba(99, 102, 241, 0.3);
        color: #a5b4fc;
    }

    .dep-btn-edit:not(:disabled):hover {
        background: rgba(99, 102, 241, 0.2);
    }

    .dep-btn-save {
        background: rgba(34, 197, 94, 0.1);
        border-color: rgba(34, 197, 94, 0.3);
        color: #4ade80;
    }

    .dep-btn-save:hover {
        background: rgba(34, 197, 94, 0.2);
    }

    .dep-btn-cancel {
        background: transparent;
        border-color: #334155;
        color: #94a3b8;
        margin-left: 0.5rem;
    }

    .dep-btn-cancel:hover {
        background: rgba(51, 65, 85, 0.4);
    }

    /* Loading */
    .dep-loading {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
    }

    .dep-spinner {
        width: 1.25rem;
        height: 1.25rem;
        border: 2px solid #334155;
        border-top-color: #6366f1;
        border-radius: 50%;
        animation: dep-spin 0.6s linear infinite;
    }

    @@keyframes dep-spin {
        to { transform: rotate(360deg); }
    }

    /* Acceso denegado */
    .dep-denied {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        text-align: center;
        padding: 1.5rem;
    }

    .dep-denied h2 {
        font-size: 1.25rem;
        font-weight: 600;
        color: #ef4444;
    }

    .dep-denied p {
        margin-top: 0.5rem;
        color: #94a3b8;
    }
</style>
