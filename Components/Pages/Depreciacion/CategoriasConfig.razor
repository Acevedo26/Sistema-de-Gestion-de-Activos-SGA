@page "/categorias"
@using Sistema_de_Gestion_de_Activos.Application.ViewModels
@using Sistema_de_Gestion_de_Activos.Application.Interfaces
@inject ICategoriaService CategoriaService

<PageTitle>Configuración de Vida Útil por Categoría</PageTitle>

<div class="flex justify-between items-center mb-6">
    <h4 class="text-xl font-bold text-gray-900 dark:text-white mb-0">Categorías de activos</h4>
    <span class="text-gray-500 dark:text-gray-400 text-sm">Solo Administradores pueden editar esta configuración</span>
</div>

<div class="bg-cyan-50 border-l-4 border-cyan-600 text-cyan-900 p-4 mb-6 rounded-r shadow-sm dark:bg-cyan-900/30 dark:border-cyan-500 dark:text-cyan-100" role="alert">
    <div class="flex items-start">
        <svg class="w-5 h-5 mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path></svg>
        <div>
            <span class="font-bold">Nota importante:</span> Modificar la vida útil de una categoría solo aplicará a activos dados de alta a partir de hoy. Los activos existentes conservarán la vida útil asignada originalmente.
        </div>
    </div>
</div>

<div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden mb-6">
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm text-gray-600 dark:text-gray-300 align-middle">
            <thead class="bg-gray-50 dark:bg-gray-700/50 text-gray-700 dark:text-gray-200 font-semibold text-xs uppercase tracking-wider border-b border-gray-200 dark:border-gray-700">
                <tr>
                    <th class="px-6 py-4">Categoría</th>
                    <th class="px-6 py-4">Vida útil actual (años)</th>
                    <th class="px-6 py-4 text-right">Acciones</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                @if (Model?.Categorias != null)
                {
                    @foreach (var categoria in Model.Categorias)
                    {
                        <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                            <td class="px-6 py-4 font-medium text-gray-900 dark:text-white">@categoria.Nombre</td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200 border border-gray-200 dark:border-gray-600">
                                    @categoria.VidaUtil años
                                </span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                @if (EsAdmin)
                                {
                                    <button class="inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-white bg-primary-600 rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors"
                                            @onclick="() => CargarEdicion(categoria)">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                        Editar
                                    </button>
                                }
                                else
                                {
                                    <span class="text-gray-400 dark:text-gray-500 text-sm inline-flex items-center justify-end gap-1">
                                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"></path></svg>
                                        Sin permisos
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@if (mostrarModal)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-gray-900/50 backdrop-blur-sm transition-opacity">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-xl border border-gray-200 dark:border-gray-700 w-full max-w-md overflow-hidden flex flex-col animate-in fade-in zoom-in duration-200">
            <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center bg-gray-50 dark:bg-gray-800/50">
                <h5 class="text-lg font-bold text-gray-900 dark:text-white">Editar vida útil</h5>
                <button type="button" class="text-gray-400 hover:text-gray-500 dark:hover:text-gray-300" @onclick="CerrarModal">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            
            <div class="p-6 flex-1">
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Categoría</label>
                        <input type="text" class="w-full rounded-md border border-gray-300 bg-gray-100 dark:bg-gray-700/50 dark:border-gray-600 dark:text-gray-400 px-3 py-2 text-sm cursor-not-allowed opacity-80" value="@categoriaEditando?.Nombre" disabled />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Nueva vida útil (años)</label>
                        <input type="number" class="w-full rounded-md border border-gray-300 dark:bg-gray-800 dark:border-gray-600 dark:text-white px-3 py-2 text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500" min="1" max="100" @bind="nuevaVidaUtil" required />
                    </div>
                    
                    <div class="bg-amber-50 border-l-4 border-amber-500 text-amber-800 p-3 rounded text-sm dark:bg-amber-900/30 dark:border-amber-500 dark:text-amber-200 flex items-start">
                        <svg class="w-4 h-4 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>
                        Este cambio solo aplicará a activos nuevos registrados a partir de hoy.
                    </div>
                </div>
            </div>
            
            <div class="px-6 py-4 border-t border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50 flex justify-end gap-3">
                <button type="button" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md shadow-sm hover:bg-gray-50 dark:bg-gray-700 dark:text-gray-200 dark:border-gray-600 dark:hover:bg-gray-600 transition-colors" @onclick="CerrarModal">Cancelar</button>
                <button type="button" class="px-4 py-2 text-sm font-medium text-white bg-primary-600 border border-transparent rounded-md shadow-sm hover:bg-primary-700 transition-colors" @onclick="GuardarCambio">Guardar cambio</button>
            </div>
        </div>
    </div>
}

@code {
    private CategoriaConfigViewModel Model = new();
    private bool mostrarModal = false;
    private CategoriaItemViewModel? categoriaEditando;
    private int nuevaVidaUtil;
    
    private bool EsAdmin = true;

    protected override async Task OnInitializedAsync()
    {
        await CargarCategorias();
    }

    private async Task CargarCategorias()
    {
        var categorias = await CategoriaService.ObtenerTodasAsync();
        Model.Categorias = categorias.Select(c => new CategoriaItemViewModel
        {
            Id = c.Id,
            Nombre = c.Nombre,
            VidaUtil = c.VidaUtil
        }).ToList();
    }

    private void CargarEdicion(CategoriaItemViewModel categoria)
    {
        categoriaEditando = categoria;
        nuevaVidaUtil = categoria.VidaUtil;
        mostrarModal = true;
    }

    private void CerrarModal()
    {
        mostrarModal = false;
        categoriaEditando = null;
    }

    private async Task GuardarCambio()
    {
        if (categoriaEditando != null)
        {
            await CategoriaService.ActualizarVidaUtilAsync(categoriaEditando.Id, nuevaVidaUtil);
            await CargarCategorias();
        }
        CerrarModal();
    }
}
