@page "/activos/{Id:guid}/depreciacion"
@using Sistema_de_Gestion_de_Activos.Application.ViewModels
@using Sistema_de_Gestion_de_Activos.Application.Interfaces
@using Microsoft.EntityFrameworkCore
@inject IDepreciacionService DepreciacionService
@inject IHistorialDepreciacionService HistorialService
@inject Sistema_de_Gestion_de_Activos.Data.SgaDbContext DbContext

<PageTitle>Depreciación del Activo</PageTitle>

@if (Model != null)
{
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4">
        <div>
            <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">@Model.Codigo - @Model.Descripcion</h3>
            <span class="text-gray-500 dark:text-gray-400 text-sm">Categoría: @Model.Categoria | Adquisición: @Model.FechaAdquisicion.ToString("dd/MM/yyyy")</span>
        </div>
        <div>
            <span class="inline-flex px-4 py-2 text-sm font-bold rounded-full bg-primary-100 text-primary-800 dark:bg-primary-900/40 dark:text-primary-300 border border-primary-200 dark:border-primary-800 shadow-sm">
                Valor actual: @Model.Depreciacion.ValorActual.ToString("C")
            </span>
        </div>
    </div>

    <!-- Progreso y Resumen Financiero -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <!-- Tarjeta: Progreso de Depreciación -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            <h5 class="text-lg font-bold text-gray-900 dark:text-white mb-4">Progreso de Depreciación</h5>
            
            <div class="flex justify-between text-sm mb-2 text-gray-600 dark:text-gray-300">
                <span>Consumido: <span class="font-bold">@Model.Depreciacion.PorcentajeConsumido.ToString("0.0")%</span></span>
                <span>Restante: <span class="font-bold">@( (100 - Model.Depreciacion.PorcentajeConsumido).ToString("0.0") )%</span></span>
            </div>
            
            <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-3 mb-6 overflow-hidden">
                <div class="@GetProgressBarColor(Model.Depreciacion.PorcentajeConsumido) h-3 rounded-full transition-all duration-500" 
                     style="width: @Model.Depreciacion.PorcentajeConsumido.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)%">
                </div>
            </div>
            
            <div class="grid grid-cols-2 gap-4 text-sm">
                <div>
                    <span class="block text-gray-500 dark:text-gray-400 text-xs uppercase tracking-wider mb-1">Costo Inicial</span>
                    <span class="font-semibold text-gray-900 dark:text-white">@Model.CostoInicial.ToString("C")</span>
                </div>
                <div>
                    <span class="block text-gray-500 dark:text-gray-400 text-xs uppercase tracking-wider mb-1">Valor Residual (Base)</span>
                    <span class="font-semibold text-gray-900 dark:text-white">@Model.Depreciacion.ValorResidual.ToString("C")</span>
                </div>
            </div>
        </div>

        <!-- Tarjeta: Detalles del Cálculo -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            <h5 class="text-lg font-bold text-gray-900 dark:text-white mb-4">Detalles del Cálculo</h5>
            <ul class="space-y-3">
                <li class="flex justify-between border-b border-gray-100 dark:border-gray-700 pb-2">
                    <span class="text-gray-600 dark:text-gray-300">Vida útil asignada:</span>
                    <span class="font-semibold text-gray-900 dark:text-white">@Model.Depreciacion.VidaUtilAsignada años</span>
                </li>
                <li class="flex justify-between border-b border-gray-100 dark:border-gray-700 pb-2">
                    <span class="text-gray-600 dark:text-gray-300">Antigüedad:</span>
                    <span class="font-semibold text-gray-900 dark:text-white">@Model.Depreciacion.AntiguedadAnios años, @Model.Depreciacion.AntiguedadMeses meses</span>
                </li>
                <li class="flex justify-between border-b border-gray-100 dark:border-gray-700 pb-2">
                    <span class="text-gray-600 dark:text-gray-300">Depreciación acumulada:</span>
                    <span class="font-semibold text-red-600 dark:text-red-400">-@Model.Depreciacion.DepreciacionAcumulada.ToString("C")</span>
                </li>
                <li class="flex justify-between pt-1">
                    <span class="text-gray-500 dark:text-gray-400 text-xs">Último cálculo del sistema:</span>
                    <span class="text-gray-500 dark:text-gray-400 text-xs">@Model.Depreciacion.FechaUltimoCalculo.ToString("dd/MM/yyyy HH:mm")</span>
                </li>
            </ul>
        </div>
    </div>

    <!-- Indicador de rentabilidad (Mantenimiento vs Depreciación) -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-6">
        <h5 class="text-lg font-bold text-gray-900 dark:text-white mb-4">Análisis de Rentabilidad</h5>
        <div class="flex flex-col md:flex-row items-center gap-6">
            <div class="w-full md:w-1/3">
                <div class="text-center p-4 rounded-lg bg-gray-50 dark:bg-gray-700/50 border border-gray-100 dark:border-gray-600">
                    <span class="block text-gray-500 dark:text-gray-400 text-xs uppercase tracking-wider mb-1">Mantenimiento Acumulado</span>
                    <span class="text-xl font-bold text-gray-900 dark:text-white">@Model.AnalisisMantenimiento.CostoMantenimientoAcumulado.ToString("C")</span>
                </div>
            </div>
            <div class="w-full md:w-2/3 flex flex-col justify-center">
                <p class="text-sm text-gray-600 dark:text-gray-300 mb-2">
                    Relación Costo de Mantenimiento / Valor Actual: 
                    <strong class="@(Model.AnalisisMantenimiento.RelacionCostoValor > Model.AnalisisMantenimiento.UmbralAlerta ? "text-red-600 dark:text-red-400" : "text-green-600 dark:text-green-400")">
                        @Model.AnalisisMantenimiento.RelacionCostoValor.ToString("0.0")%
                    </strong>
                </p>
                @if (Model.AnalisisMantenimiento.RelacionCostoValor > Model.AnalisisMantenimiento.UmbralAlerta)
                {
                    <div class="bg-red-50 border-l-4 border-red-500 text-red-800 p-3 rounded text-sm dark:bg-red-900/30 dark:border-red-500 dark:text-red-200 flex items-start">
                        <svg class="w-4 h-4 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>
                        <strong>Alerta financiera:</strong> El costo de mantener este activo está superando el umbral recomendado (@Model.AnalisisMantenimiento.UmbralAlerta%). Se sugiere considerar su reemplazo.
                    </div>
                }
                else
                {
                    <div class="bg-green-50 border-l-4 border-green-500 text-green-800 p-3 rounded text-sm dark:bg-green-900/30 dark:border-green-500 dark:text-green-200 flex items-start">
                        <svg class="w-4 h-4 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                        El activo se mantiene dentro de niveles de rentabilidad óptimos.
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden mb-6">
        <div class="border-b border-gray-200 dark:border-gray-700 px-4">
            <nav class="-mb-px flex space-x-6" aria-label="Tabs">
                <button @onclick="() => tabActiva = 1" class="@(tabActiva == 1 ? "border-primary-500 text-primary-600 dark:text-primary-400" : "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 dark:text-gray-400 dark:hover:text-gray-300") whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-colors">
                    Historial de Depreciación (Mensual)
                </button>
                <button @onclick="() => tabActiva = 2" class="@(tabActiva == 2 ? "border-primary-500 text-primary-600 dark:text-primary-400" : "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 dark:text-gray-400 dark:hover:text-gray-300") whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-colors">
                    Auditoría de Cambios
                </button>
            </nav>
        </div>
        
        <div class="p-0">
            @if (tabActiva == 1)
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm text-gray-600 dark:text-gray-300">
                        <thead class="bg-gray-50 dark:bg-gray-700/50 text-gray-700 dark:text-gray-200 font-semibold text-xs uppercase tracking-wider">
                            <tr>
                                <th class="px-6 py-3 border-b border-gray-200 dark:border-gray-700">Fecha de Corte</th>
                                <th class="px-6 py-3 border-b border-gray-200 dark:border-gray-700">Valor Contable</th>
                                <th class="px-6 py-3 border-b border-gray-200 dark:border-gray-700 text-right">Depreciación Acum.</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                            @foreach (var hist in Model.Historial.OrderByDescending(h => h.FechaConsulta))
                            {
                                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50">
                                    <td class="px-6 py-3">@hist.FechaConsulta.ToString("MMM yyyy")</td>
                                    <td class="px-6 py-3 font-medium text-gray-900 dark:text-white">@hist.ValorActual.ToString("C")</td>
                                    <td class="px-6 py-3 text-right text-red-600 dark:text-red-400">@hist.DepreciacionAcumulada.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else if (tabActiva == 2)
            {
                <div class="p-6">
                    <div class="flow-root">
                        <ul role="list" class="-mb-8">
                            @foreach (var (auditoria, index) in Model.Auditoria.Select((a, i) => (a, i)))
                            {
                                <li>
                                    <div class="relative pb-8">
                                        @if (index != Model.Auditoria.Count - 1)
                                        {
                                            <span class="absolute top-4 left-4 -ml-px h-full w-0.5 bg-gray-200 dark:bg-gray-700" aria-hidden="true"></span>
                                        }
                                        <div class="relative flex space-x-3">
                                            <div>
                                                <span class="h-8 w-8 rounded-full bg-primary-100 dark:bg-primary-900 flex items-center justify-center ring-8 ring-white dark:ring-gray-800">
                                                    <svg class="h-4 w-4 text-primary-600 dark:text-primary-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                                </span>
                                            </div>
                                            <div class="min-w-0 flex-1 pt-1.5 flex justify-between space-x-4">
                                                <div>
                                                    <p class="text-sm text-gray-600 dark:text-gray-300">
                                                        <span class="font-medium text-gray-900 dark:text-white">@auditoria.Usuario</span> 
                                                        @auditoria.Accion - <span class="italic">@auditoria.Cambios</span>
                                                    </p>
                                                </div>
                                                <div class="text-right text-sm whitespace-nowrap text-gray-500 dark:text-gray-400">
                                                    @auditoria.Fecha.ToString("dd/MM/yyyy HH:mm")
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private ActivoDetalleViewModel? Model;
    private int tabActiva = 1;

    protected override async Task OnInitializedAsync()
    {
        var activo = await DbContext.Activos
            .Include(a => a.Categoria)
            .FirstOrDefaultAsync(a => a.Id == Id);

        if (activo == null) return;

        var detalleFinanciero = await DepreciacionService.ObtenerDetalleFinancieroAsync(Id);
        var historial = await HistorialService.ObtenerHistorialPorActivoAsync(Id);

        if (detalleFinanciero == null) return;

        Model = new ActivoDetalleViewModel
        {
            Id = Id,
            Codigo = activo.Codigo,
            Descripcion = activo.Descripcion,
            Categoria = activo.Categoria.Nombre,
            FechaAdquisicion = activo.FechaAdquisicion,
            CostoInicial = activo.CostoInicial,
            Depreciacion = new DepreciacionDetalleViewModel
            {
                ValorActual = detalleFinanciero.ValorActual,
                ValorResidual = detalleFinanciero.ValorResidual,
                DepreciacionAcumulada = detalleFinanciero.ValorOriginal - detalleFinanciero.ValorActual,
                PorcentajeConsumido = detalleFinanciero.PorcentajeConsumido,
                VidaUtilAsignada = detalleFinanciero.VidaUtilAsignada,
                AntiguedadAnios = detalleFinanciero.AntiguedadAnios,
                AntiguedadMeses = detalleFinanciero.AntiguedadMeses,
                FechaUltimoCalculo = DateTime.Now
            },
            AnalisisMantenimiento = new AnalisisMantenimientoViewModel
            {
                CostoMantenimientoAcumulado = 3500m,
                RelacionCostoValor = 45.1m,
                UmbralAlerta = 40.0m
            },
            Historial = historial.Select(h => new HistorialDepreciacionViewModel
            {
                FechaConsulta = h.FechaConsulta,
                ValorActual = h.ValorActual,
                DepreciacionAcumulada = h.DepreciacionAcumulada
            }).ToList(),
            Auditoria = new List<AuditoriaItemViewModel>
            {
                new AuditoriaItemViewModel { Fecha = DateTime.Now.AddDays(-2), Usuario = "Sistema", Accion = "Cálculo Mensual", Cambios = "Cálculo automático de depreciación." }
            }
        };
    }

    private string GetProgressBarColor(decimal porcentaje)
    {
        if (porcentaje < 50) return "bg-green-500";
        if (porcentaje < 80) return "bg-yellow-400";
        return "bg-red-500";
    }
}
