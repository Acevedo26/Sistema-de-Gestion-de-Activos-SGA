@page "/recuperar-password"
@layout Layout._Layout
@inject Sistema_de_Gestion_de_Activos.Application.Interfaces.IAuthService AuthService

@code {
    private bool isLoading = false;
    private string email = string.Empty;
    private string error = string.Empty;
    private bool success = false;

    private async Task HandleSubmit()
    {
        error = string.Empty;
        success = false;

        if (string.IsNullOrWhiteSpace(email) || !email.Contains("@"))
        {
            error = "Por favor ingrese un correo válido.";
            return;
        }

        isLoading = true;

        try
        {
            await AuthService.SolicitarRecuperacionAsync(email);
            success = true;
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}

<div class="flex min-h-screen w-full items-center justify-center bg-gray-50 p-4 dark:bg-gray-950">
    <Card class="w-full max-w-[400px]">
        <CardHeader class="flex flex-col items-center space-y-4 pb-6 pt-8">
            <div class="flex h-16 w-16 items-center justify-center rounded-xl bg-primary-600 text-white shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                </svg>
            </div>
            <div class="text-center">
                <h1 class="text-lg font-semibold text-gray-900 dark:text-white">
                    Recuperar Contraseña
                </h1>
                <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
                    Ingrese su correo y le enviaremos un enlace para restablecer su contraseña.
                </p>
            </div>
        </CardHeader>

        <CardContent>
            @if (success)
            {
                <div class="rounded-md bg-green-50 p-4 text-sm text-green-800 dark:bg-green-900/30 dark:text-green-400">
                    Si el correo existe en nuestro sistema, recibirá un enlace para restablecer su contraseña en breve.
                </div>
                <div class="mt-6 text-center">
                    <a href="/login" class="text-sm font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400">
                        Volver al inicio de sesión
                    </a>
                </div>
            }
            else
            {
                <EditForm Model="@this" OnSubmit="HandleSubmit" class="space-y-4">
                    <Input Label="Correo Electrónico"
                           Type="email"
                           placeholder="correo@empresa.com"
                           @bind-Value="email"
                           Error="@(error != string.Empty && string.IsNullOrWhiteSpace(email) ? "Requerido" : null)" />

                    @if (!string.IsNullOrEmpty(error))
                    {
                        <div class="rounded-md bg-red-50 p-3 text-sm text-red-600 dark:bg-red-900/20 dark:text-red-400">
                            @error
                        </div>
                    }

                    <Button Type="submit"
                            Class="w-full mt-2 h-11"
                            IsLoading="isLoading">
                        Enviar enlace de recuperación
                    </Button>
                </EditForm>
                
                <div class="mt-4 text-center">
                    <a href="/login"
                       class="text-sm text-gray-500 hover:text-gray-700 hover:underline dark:text-gray-400 dark:hover:text-gray-300">
                        Volver al inicio de sesión
                    </a>
                </div>
            }
        </CardContent>
    </Card>
</div>
