@page "/mantenimiento"
@using Sistema_de_Gestion_de_Activos.Application.DTOs.Mantenimiento
@using Sistema_de_Gestion_de_Activos.Application.Interfaces
@using Sistema_de_Gestion_de_Activos.Domain.Enums
@inject IMantenimientoService MantenimientoService
@inject NavigationManager Navigation

<PageTitle>Mantenimiento de Activos</PageTitle>

<div class="flex justify-between items-center mb-6">
    <h4 class="text-xl font-bold text-gray-900 dark:text-white mb-0">Mantenimiento de Activos</h4>
    <button class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-primary-600 rounded-md hover:bg-primary-700 transition-colors"
            @onclick="IrARegistrar">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
        Nuevo Mantenimiento
    </button>
</div>

<div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden mb-6">
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm text-gray-600 dark:text-gray-300 align-middle">
            <thead class="bg-gray-50 dark:bg-gray-700/50 text-gray-700 dark:text-gray-200 font-semibold text-xs uppercase tracking-wider border-b border-gray-200 dark:border-gray-700">
                <tr>
                    <th class="px-6 py-4">Activo</th>
                    <th class="px-6 py-4">Técnico</th>
                    <th class="px-6 py-4">Tipo</th>
                    <th class="px-6 py-4">Estado</th>
                    <th class="px-6 py-4">Fecha Inicio</th>
                    <th class="px-6 py-4">Fecha Fin</th>
                    <th class="px-6 py-4">Costo</th>
                    <th class="px-6 py-4 text-right">Acciones</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                @if (mantenimientos != null)
                {
                    @foreach (var m in mantenimientos)
                    {
                        <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                            <td class="px-6 py-4 font-medium text-gray-900 dark:text-white">@m.ActivoDescripcion</td>
                            <td class="px-6 py-4">@m.TecnicoNombre</td>
                            <td class="px-6 py-4">@m.Tipo</td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @EstadoBadgeClass(m.Estado)">
                                    @m.Estado
                                </span>
                            </td>
                            <td class="px-6 py-4">@m.FechaInicio.ToString("dd/MM/yyyy")</td>
                            <td class="px-6 py-4">@(m.FechaFin.HasValue ? m.FechaFin.Value.ToString("dd/MM/yyyy") : "—")</td>
                            <td class="px-6 py-4">₡@m.Costo.ToString("N2")</td>
                            <td class="px-6 py-4 text-right">
                                @if (m.Estado != EstadoMantenimiento.Finalizado)
                                {
                                    <button class="inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-white bg-green-600 rounded-md hover:bg-green-700 transition-colors"
                                            @onclick="() => IrAFinalizar(m.Id)">
                                        Finalizar
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                    @if (!mantenimientos.Any())
                    {
                        <tr>
                            <td colspan="8" class="px-6 py-8 text-center text-gray-400">
                                No hay mantenimientos registrados todavía.
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<div class="flex justify-end">
    <a href="/mantenimiento/programas" class="text-sm font-medium text-primary-600 hover:text-primary-700">
        Ver programas de mantenimiento preventivo →
    </a>
</div>

@code {
    private List<MantenimientoResponseDto>? mantenimientos;

    protected override async Task OnInitializedAsync()
    {
        mantenimientos = (await MantenimientoService.ObtenerTodosAsync()).ToList();
    }

    private void IrARegistrar() => Navigation.NavigateTo("/mantenimiento/registrar");

    private void IrAFinalizar(Guid id) => Navigation.NavigateTo($"/mantenimiento/finalizar/{id}");

    private string EstadoBadgeClass(EstadoMantenimiento estado) => estado switch
    {
        EstadoMantenimiento.Finalizado => "bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400",
        EstadoMantenimiento.EnProgreso => "bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400",
        _ => "bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-300"
    };
}
