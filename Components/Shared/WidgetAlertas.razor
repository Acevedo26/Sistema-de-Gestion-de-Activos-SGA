@using Sistema_de_Gestion_de_Activos.Application.ViewModels

@if (Model?.Alertas != null && Model.Alertas.Any())
{
    <div class="bg-red-50 dark:bg-red-900/10 rounded-xl shadow-sm border border-red-200 dark:border-red-800/50 mb-6 overflow-hidden">
        <div class="px-6 py-4 border-b border-red-100 dark:border-red-800/30 flex items-center bg-red-100/50 dark:bg-red-900/20">
            <svg class="w-5 h-5 text-red-600 dark:text-red-500 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>
            <h5 class="text-lg font-bold text-red-800 dark:text-red-400 m-0">Activos próximos a depreciarse por completo</h5>
        </div>
        
        <div class="p-0">
            <div class="divide-y divide-red-100 dark:divide-red-800/30">
                @foreach (var alerta in Model.Alertas)
                {
                    <div class="px-6 py-3 flex justify-between items-center hover:bg-red-100/30 dark:hover:bg-red-900/30 transition-colors">
                        <div>
                            <span class="font-bold text-red-900 dark:text-red-300">@alerta.Codigo</span>
                            <span class="text-red-700 dark:text-red-400 text-sm ml-2">@alerta.Descripcion</span>
                        </div>
                        <div class="text-right">
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-200 text-red-800 dark:bg-red-900 dark:text-red-200">
                                @alerta.PorcentajeConsumido.ToString("0.0")% consumido
                            </span>
                            <a href="/activos/@alerta.ActivoId/depreciacion" class="ml-3 text-sm font-medium text-red-600 hover:text-red-500 dark:text-red-400 dark:hover:text-red-300 underline">Ver detalle</a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public AlertasDepreciacionViewModel? Model { get; set; }

    protected override void OnInitialized()
    {
        if (Model == null)
        {
            Model = new AlertasDepreciacionViewModel
            {
                Alertas = new List<AlertaDepreciacionItemViewModel>
                {
                    new AlertaDepreciacionItemViewModel
                    {
                        ActivoId = Guid.NewGuid(),
                        Codigo = "MOB-0012",
                        Descripcion = "Escritorio Presidencial",
                        PorcentajeConsumido = 95.5m
                    },
                    new AlertaDepreciacionItemViewModel
                    {
                        ActivoId = Guid.NewGuid(),
                        Codigo = "COMP-0089",
                        Descripcion = "Monitor LG 27''",
                        PorcentajeConsumido = 98.0m
                    }
                }
            };
        }
    }
}
